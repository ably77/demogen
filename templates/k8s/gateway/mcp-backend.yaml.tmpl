apiVersion: agentgateway.dev/v1alpha1
kind: AgentgatewayBackend
metadata:
  name: {{MCP_SERVICE_NAME}}-backend
  namespace: agentgateway-system
spec:
  mcp:
    targets:
    - name: {{MCP_SERVICE_NAME}}-target
      static:
        host: {{MCP_SERVICE_NAME}}.{{NS_BACKEND}}.svc.cluster.local
        port: 8082
        protocol: StreamableHTTP
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{MCP_SERVICE_NAME}}
  namespace: agentgateway-system
spec:
  parentRefs:
  - name: agentgateway-proxy
    namespace: agentgateway-system
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /{{MCP_SERVICE_NAME}}
    backendRefs:
    - name: {{MCP_SERVICE_NAME}}-backend
      group: agentgateway.dev
      kind: AgentgatewayBackend
    timeouts:
      request: "0s"
